{
  "name": "genesis-mesh-sdk",
  "version": "0.53.0",
  "description": "TypeScript client for the Genesis Mesh Network Authority API — sovereign trust, attestation, and capability enforcement",
  "type": "module",
  "license": "MIT",
  "author": "Genesis Mesh Labs",
  "homepage": "https://github.com/GenesisMeshLabs/sdk-typescript#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/GenesisMeshLabs/sdk-typescript.git"
  },
  "bugs": {
    "url": "https://github.com/GenesisMeshLabs/sdk-typescript/issues"
  },
  "keywords": [
    "genesis-mesh",
    "trust",
    "attestation",
    "sovereign",
    "network-authority",
    "ed25519",
    "zero-trust",
    "capability"
  ],
  "engines": { "node": ">=22.0.0" },
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "files": ["dist", "README.md", "LICENSE", "CHANGELOG.md"],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.cjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.4.0"
  }
}
